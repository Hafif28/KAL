"end":{"line":10,"column":1}},"key":"UmOC56Gc4l"},{"type":"strong","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Substitusi Balik (Back-Substitution)","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"nJ25P12xep"}],"key":"kfE1PRIYR5"},{"type":"text","value":" mulai dari baris terbawah untuk menemukan nilai setiap variabel. Jika menggunakan RREF, solusi seringkali dapat langsung dibaca dari matriks tersebut.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"X1Cw66gASR"}],"key":"hbZxRP0fL5"}],"key":"bn9H0Rnmzo"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\n# Inisialisasi Matriks A\nA = np.array([\n    [0, 2, 4],\n    [1, 3, 5],\n    [2, 4, 8]\n], dtype=float)\n\nprint(\"Matriks Awal:\")\nprint(A)\n\n# 1. Pertukaran Baris (R1 <-> R2)\n# Menukar baris 0 dengan baris 1 karena A[0,0] adalah 0 (tidak bisa jadi pivot)\nA[[0, 1]] = A[[1, 0]]\n\nprint(\"\\nSetelah Pertukaran Baris (R1 <-> R2):\")\nprint(A)","key":"Bo6ggvnnJI"},{"type":"outputs","id":"1X48CB6r7nisoi1KAUvrV","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Matriks Awal:\n[[0. 2. 4.]\n [1. 3. 5.]\n [2. 4. 8.]]\n\nSetelah Pertukaran Baris (R1 <-> R2):\n[[1. 3. 5.]\n [0. 2. 4.]\n [2. 4. 8.]]\n"},"children":[],"key":"tKuacdUNoZ"}],"key":"yfM3BYyUcu"}],"key":"o3X0qiDl6k"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Melanjutkan dari matriks sebelumnya\n# 2. Perkalian Baris dengan Konstanta (1/2 * R2 -> R2)\n# Misal kita ingin menyederhanakan baris ke-3 (indeks 2)\nA[2] = 0.5 * A[2]\n\nprint(\"Setelah Perkalian Baris (0.5 * R3 -> R3):\")\nprint(A)","key":"cZN2N6sfV4"},{"type":"outputs","id":"q9J36at-mxGE8HNN7JOQo","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Setelah Perkalian Baris (0.5 * R3 -> R3):\n[[1. 3. 5.]\n [0. 2. 4.]\n [1. 2. 4.]]\n"},"children":[],"key":"Eh8cXUBhz6"}],"key":"xcSsCzCTVF"}],"key":"PyyfQGHQAI"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Melanjutkan dari matriks sebelumnya\n# 3. Penjumlahan Kelipatan Baris (R3 + (-1)*R1 -> R3)\n# Menggunakan baris 1 (indeks 0) untuk menolkan elemen di baris 3 (indeks 2) kolom 1\n# Rumus: R3 = R3 - 1*R1\nA[2] = A[2] - 1 * A[0]\n\nprint(\"Setelah Penjumlahan Kelipatan Baris (R3 - R1 -> R3):\")\nprint(A)","key":"GyjDqQ3SMF"},{"type":"outputs","id":"EY3AFBIUmVS8bAUcfrqMH","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Setelah Penjumlahan Kelipatan Baris (R3 - R1 -> R3):\n[[ 1.  3.  5.]\n [ 0.  2.  4.]\n [ 0. -1. -1.]]\n"},"children":[],"key":"Do5VDIz5RV"}],"key":"YdjimL1eMf"}],"key":"WiODkmYnju"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Melanjutkan ke Row Echelon Form (REF)\n# Pada langkah sebelumnya (sebelum sel ini), matriks A adalah:\n# [[ 1.  3.  5.]\n#  [ 0.  2.  4.]\n#  [ 0. -1. -1.]]\n\n# Langkah 4: Hilangkan angka -1 di baris 3 kolom 2 menggunakan baris 2 (R2)\n# Kita bisa menjumlahkan R3 dengan 0.5 * R2 agar elemen di kolom 2 menjadi 0\n# R3 = R3 + 0.5 * R2\nA[2] = A[2] + 0.5 * A[1]\n\nprint(\"Setelah R3 + 0.5 * R2 (Mencapai Bentuk REF):\")\nprint(A)\n\n# Langkah 5 (Opsional): Membuat pivot menjadi 1 (Leading 1)\n# Baris 2 memiliki pivot 2. Kita bagi dengan 2.\n# R2 = 1/2 * R2\nA[1] = 0.5 * A[1]\n\nprint(\"\\nSetelah R2 * 0.5 (Leading 1 pada baris 2):\")\nprint(A)","key":"sa1RifwCMz"},{"type":"outputs","id":"iGYpVPev2lKEUfiQvY86v","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Setelah R3 + 0.5 * R2 (Mencapai Bentuk REF):\n[[1. 3. 5.]\n [0. 2. 4.]\n [0. 0. 1.]]\n\nSetelah R2 * 0.5 (Leading 1 pada baris 2):\n[[1. 3. 5.]\n [0. 1. 2.]\n [0. 0. 1.]]\n"},"children":[],"key":"BwtLykE7qO"}],"key":"IwYg6I1q5T"}],"key":"aij58EYm5r"},{"type":"block","kind":"notebook-content","children":[{"type":"iframe","style":{"border":"0px"},"src":"https://www.geogebra.org/material/iframe/id/qzgpq9gz/width/631/height/400/border/888888/sfsb/true/smb/false/stb/false/stbh/false/ai/false/asb/false/sri/true/rc/false/ld/false/sdz/true/ctl/false","width":"100%","title":"Graph the Line","key":"BgnwHtxUv0"}],"key":"RYQzf8wIe3"},{"type":"block","kind":"notebook-content","children":[{"type":"iframe","style":{"border":"0px"},"src":"https://www.geogebra.org/material/iframe/id/kpqftj8p/width/631/height/400/border/888888/sfsb/true/smb/false/stb/false/stbh/false/ai/false/asb/false/sri/true/rc/false/ld/false/sdz/true/ctl/false","width":"100%","title":"Graph the Line","key":"z5dcfysgod"}],"key":"ZFaz15HA1L"},{"type":"block","kind":"notebook-content","children":[{"type":"iframe","style":{"border":"0px"},"src":"https://www.geogebra.org/material/iframe/id/mx8ejtvv/width/631/height/400/border/888888/sfsb/true/smb/false/stb/false/stbh/false/ai/false/asb/false/sri/true/rc/false/ld/false/sdz/true/ctl/false","width":"100%","title":"Graph the Line","key":"vQ3STkpXVr"}],"key":"yPo7HwpKa7"}],"key":"JIbZfAsTbr"},"references":{"cite":{"order":[],"data":{}}}}