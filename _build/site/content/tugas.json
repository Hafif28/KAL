B:\")\nprint(TAB)\n\nprint(\"\\n=====================================\\n\")\n\n\n# =====================================================\n# 2. TRANSFORMASI B → C\n# =====================================================\n\nB = (2, 1)\nC = (4, 1)\n\nprint(\"TRANSFORMASI B → C\")\nprint(\"Titik B =\", B)\nprint(\"Titik C =\", C)\n\ndx2 = C[0] - B[0]\ndy2 = C[1] - B[1]\n\nprint(\"\\nPerhitungan:\")\nprint(\"Δx =\", C[0], \"-\", B[0], \"=\", dx2)\nprint(\"Δy =\", C[1], \"-\", B[1], \"=\", dy2)\n\nTBC = np.array([\n    [1, 0, dx2],\n    [0, 1, dy2],\n    [0, 0, 1]\n])\n\nprint(\"\\nMatriks Transformasi B → C:\")\nprint(TBC)\n\nprint(\"\\n=====================================\\n\")\n\n\n# =====================================================\n# 3. TRANSFORMASI D → E\n# =====================================================\n\nD = (2, 4)\nE = (2, 0)\n\nprint(\"TRANSFORMASI D → E\")\nprint(\"Titik D =\", D)\nprint(\"Titik E =\", E)\n\ndx3 = E[0] - D[0]\ndy3 = E[1] - D[1]\n\nprint(\"\\nPerhitungan:\")\nprint(\"Δx =\", E[0], \"-\", D[0], \"=\", dx3)\nprint(\"Δy =\", E[1], \"-\", D[1], \"=\", dy3)\n\nTDE = np.array([\n    [1, 0, dx3],\n    [0, 1, dy3],\n    [0, 0, 1]\n])\n\nprint(\"\\nMatriks Transformasi D → E:\")\nprint(TDE)\n\nprint(\"\\n=====================================\\n\")\n\n\n# =====================================================\n# 4. TRANSFORMASI E → F\n# =====================================================\n\nE = (2, 0)\nF = (4, 0)\n\nprint(\"TRANSFORMASI E → F\")\nprint(\"Titik E =\", E)\nprint(\"Titik F =\", F)\n\ndx4 = F[0] - E[0]\ndy4 = F[1] - E[1]\n\nprint(\"\\nPerhitungan:\")\nprint(\"Δx =\", F[0], \"-\", E[0], \"=\", dx4)\nprint(\"Δy =\", F[1], \"-\", E[1], \"=\", dy4)\n\nTEF = np.array([\n    [1, 0, dx4],\n    [0, 1, dy4],\n    [0, 0, 1]\n])\n\nprint(\"\\nMatriks Transformasi E → F:\")\nprint(TEF)\n\nprint(\"\\n=====================================\")","key":"Qoc0EFmxdd"},{"type":"outputs","id":"8l9PU6JO1tCI8YilDnFsT","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"TRANSFORMASI A → B\nTitik A = (2, 3)\nTitik B = (2, 1)\n\nPerhitungan:\nΔx = 2 - 2 = 0\nΔy = 1 - 3 = -2\n\nMatriks Transformasi A → B:\n[[ 1  0  0]\n [ 0  1 -2]\n [ 0  0  1]]\n\n=====================================\n\nTRANSFORMASI B → C\nTitik B = (2, 1)\nTitik C = (4, 1)\n\nPerhitungan:\nΔx = 4 - 2 = 2\nΔy = 1 - 1 = 0\n\nMatriks Transformasi B → C:\n[[1 0 2]\n [0 1 0]\n [0 0 1]]\n\n=====================================\n\nTRANSFORMASI D → E\nTitik D = (2, 4)\nTitik E = (2, 0)\n\nPerhitungan:\nΔx = 2 - 2 = 0\nΔy = 0 - 4 = -4\n\nMatriks Transformasi D → E:\n[[ 1  0  0]\n [ 0  1 -4]\n [ 0  0  1]]\n\n=====================================\n\nTRANSFORMASI E → F\nTitik E = (2, 0)\nTitik F = (4, 0)\n\nPerhitungan:\nΔx = 4 - 2 = 2\nΔy = 0 - 0 = 0\n\nMatriks Transformasi E → F:\n[[1 0 2]\n [0 1 0]\n [0 0 1]]\n\n=====================================\n"},"children":[],"key":"kcwqGgKNg5"}],"key":"D5pSVCeyxR"}],"key":"KnZrztsPU3"}],"key":"Lfpz1TGveB"},"references":{"cite":{"order":[],"data":{}}}}