n":1},"end":{"line":10,"column":1}},"key":"C6WRvooj5L"},{"type":"strong","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Substitusi Balik (Back-Substitution)","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"mCnE23E911"}],"key":"v0d1q2xrHe"},{"type":"text","value":" mulai dari baris terbawah untuk menemukan nilai setiap variabel. Jika menggunakan RREF, solusi seringkali dapat langsung dibaca dari matriks tersebut.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"C0pGXfx0Du"}],"key":"rJkSjyOieV"}],"key":"qVn6CBxWUM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\n# Inisialisasi Matriks A\nA = np.array([\n    [0, 2, 4],\n    [1, 3, 5],\n    [2, 4, 8]\n], dtype=float)\n\nprint(\"Matriks Awal:\")\nprint(A)\n\n# 1. Pertukaran Baris (R1 <-> R2)\n# Menukar baris 0 dengan baris 1 karena A[0,0] adalah 0 (tidak bisa jadi pivot)\nA[[0, 1]] = A[[1, 0]]\n\nprint(\"\\nSetelah Pertukaran Baris (R1 <-> R2):\")\nprint(A)","key":"Occ2YCbqDv"},{"type":"outputs","id":"MvJHmmvyHk2uiPbfnHhOp","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Matriks Awal:\n[[0. 2. 4.]\n [1. 3. 5.]\n [2. 4. 8.]]\n\nSetelah Pertukaran Baris (R1 <-> R2):\n[[1. 3. 5.]\n [0. 2. 4.]\n [2. 4. 8.]]\n"},"children":[],"key":"fAfj3tnVqW"}],"key":"SWyP3nH1jT"}],"key":"PLlzpq9TUo"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Melanjutkan dari matriks sebelumnya\n# 2. Perkalian Baris dengan Konstanta (1/2 * R2 -> R2)\n# Misal kita ingin menyederhanakan baris ke-3 (indeks 2)\nA[2] = 0.5 * A[2]\n\nprint(\"Setelah Perkalian Baris (0.5 * R3 -> R3):\")\nprint(A)","key":"UhrFEbZQup"},{"type":"outputs","id":"8grQ-bUX_nqH7D0FrtMiK","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Setelah Perkalian Baris (0.5 * R3 -> R3):\n[[1. 3. 5.]\n [0. 2. 4.]\n [1. 2. 4.]]\n"},"children":[],"key":"kSncxSuH60"}],"key":"wzZzvCaz0e"}],"key":"LVjvqMjLPp"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Melanjutkan dari matriks sebelumnya\n# 3. Penjumlahan Kelipatan Baris (R3 + (-1)*R1 -> R3)\n# Menggunakan baris 1 (indeks 0) untuk menolkan elemen di baris 3 (indeks 2) kolom 1\n# Rumus: R3 = R3 - 1*R1\nA[2] = A[2] - 1 * A[0]\n\nprint(\"Setelah Penjumlahan Kelipatan Baris (R3 - R1 -> R3):\")\nprint(A)","key":"UKa0B4ierm"},{"type":"outputs","id":"cBDQxlxYr6w6YuykCLGYH","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Setelah Penjumlahan Kelipatan Baris (R3 - R1 -> R3):\n[[ 1.  3.  5.]\n [ 0.  2.  4.]\n [ 0. -1. -1.]]\n"},"children":[],"key":"RmN3tfkThz"}],"key":"hRuDvElH8F"}],"key":"i4SfUyGBSm"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Melanjutkan ke Row Echelon Form (REF)\n# Pada langkah sebelumnya (sebelum sel ini), matriks A adalah:\n# [[ 1.  3.  5.]\n#  [ 0.  2.  4.]\n#  [ 0. -1. -1.]]\n\n# Langkah 4: Hilangkan angka -1 di baris 3 kolom 2 menggunakan baris 2 (R2)\n# Kita bisa menjumlahkan R3 dengan 0.5 * R2 agar elemen di kolom 2 menjadi 0\n# R3 = R3 + 0.5 * R2\nA[2] = A[2] + 0.5 * A[1]\n\nprint(\"Setelah R3 + 0.5 * R2 (Mencapai Bentuk REF):\")\nprint(A)\n\n# Langkah 5 (Opsional): Membuat pivot menjadi 1 (Leading 1)\n# Baris 2 memiliki pivot 2. Kita bagi dengan 2.\n# R2 = 1/2 * R2\nA[1] = 0.5 * A[1]\n\nprint(\"\\nSetelah R2 * 0.5 (Leading 1 pada baris 2):\")\nprint(A)","key":"ULIOSCcY2B"},{"type":"outputs","id":"AdA-d4T-CcWPeRNEC1yR5","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Setelah R3 + 0.5 * R2 (Mencapai Bentuk REF):\n[[1. 3. 5.]\n [0. 2. 4.]\n [0. 0. 1.]]\n\nSetelah R2 * 0.5 (Leading 1 pada baris 2):\n[[1. 3. 5.]\n [0. 1. 2.]\n [0. 0. 1.]]\n"},"children":[],"key":"B3vEa8tckO"}],"key":"nJgwdVqFlU"}],"key":"qXINN6JlHo"},{"type":"block","kind":"notebook-content","children":[{"type":"iframe","style":{"border":"0px"},"src":"https://www.geogebra.org/material/iframe/id/qzgpq9gz/width/631/height/400/border/888888/sfsb/true/smb/false/stb/false/stbh/false/ai/false/asb/false/sri/true/rc/false/ld/false/sdz/true/ctl/false","width":"100%","title":"Graph the Line","key":"uMu4KB2Cnz"}],"key":"xKW072PVLW"},{"type":"block","kind":"notebook-content","children":[{"type":"iframe","style":{"border":"0px"},"src":"https://www.geogebra.org/material/iframe/id/kpqftj8p/width/631/height/400/border/888888/sfsb/true/smb/false/stb/false/stbh/false/ai/false/asb/false/sri/true/rc/false/ld/false/sdz/true/ctl/false","width":"100%","title":"Graph the Line","key":"ArhGW0NaVp"}],"key":"NcQsv3VJET"},{"type":"block","kind":"notebook-content","children":[{"type":"iframe","style":{"border":"0px"},"src":"https://www.geogebra.org/material/iframe/id/mx8ejtvv/width/631/height/400/border/888888/sfsb/true/smb/false/stb/false/stbh/false/ai/false/asb/false/sri/true/rc/false/ld/false/sdz/true/ctl/false","width":"100%","title":"Graph the Line","key":"AyuIEBfK4I"}],"key":"x6cSuBiPRF"}],"key":"eAShlyjOs9"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Komputasi Aljabar Linear (KAL)","url":"/persamaan-linear","group":"Komputasi Aljabar Linear"},"next":{"title":"Tugas","url":"/tugas-persamaan-gausian","group":"Komputasi Aljabar Linear"}}},"domain":"http://localhost:3001"}