n":1},"end":{"line":10,"column":1}},"key":"at8gEuw5Si"},{"type":"strong","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Substitusi Balik (Back-Substitution)","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"IJmDbCaN8y"}],"key":"bz4m87KuYU"},{"type":"text","value":" mulai dari baris terbawah untuk menemukan nilai setiap variabel. Jika menggunakan RREF, solusi seringkali dapat langsung dibaca dari matriks tersebut.","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"APjRAI70mq"}],"key":"BmbgOQdtcm"}],"key":"nz7kc8447Y"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\n\n# Inisialisasi Matriks A\nA = np.array([\n    [0, 2, 4],\n    [1, 3, 5],\n    [2, 4, 8]\n], dtype=float)\n\nprint(\"Matriks Awal:\")\nprint(A)\n\n# 1. Pertukaran Baris (R1 <-> R2)\n# Menukar baris 0 dengan baris 1 karena A[0,0] adalah 0 (tidak bisa jadi pivot)\nA[[0, 1]] = A[[1, 0]]\n\nprint(\"\\nSetelah Pertukaran Baris (R1 <-> R2):\")\nprint(A)","key":"VhCWh1aDVR"},{"type":"outputs","id":"6bNqAYnrXXaPdIPL1jp7G","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Matriks Awal:\n[[0. 2. 4.]\n [1. 3. 5.]\n [2. 4. 8.]]\n\nSetelah Pertukaran Baris (R1 <-> R2):\n[[1. 3. 5.]\n [0. 2. 4.]\n [2. 4. 8.]]\n"},"children":[],"key":"rGJcI9wmhf"}],"key":"wyc1IoVKQE"}],"key":"Flb2dudmyd"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Melanjutkan dari matriks sebelumnya\n# 2. Perkalian Baris dengan Konstanta (1/2 * R2 -> R2)\n# Misal kita ingin menyederhanakan baris ke-3 (indeks 2)\nA[2] = 0.5 * A[2]\n\nprint(\"Setelah Perkalian Baris (0.5 * R3 -> R3):\")\nprint(A)","key":"XQpRhzjVgM"},{"type":"outputs","id":"xPaZm7KtkiDnqKfKhMBP5","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Setelah Perkalian Baris (0.5 * R3 -> R3):\n[[1. 3. 5.]\n [0. 2. 4.]\n [1. 2. 4.]]\n"},"children":[],"key":"IaVPRb4FdC"}],"key":"EU6sRQIs1K"}],"key":"YWecSyYMLl"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Melanjutkan dari matriks sebelumnya\n# 3. Penjumlahan Kelipatan Baris (R3 + (-1)*R1 -> R3)\n# Menggunakan baris 1 (indeks 0) untuk menolkan elemen di baris 3 (indeks 2) kolom 1\n# Rumus: R3 = R3 - 1*R1\nA[2] = A[2] - 1 * A[0]\n\nprint(\"Setelah Penjumlahan Kelipatan Baris (R3 - R1 -> R3):\")\nprint(A)","key":"IkkY5NLDhg"},{"type":"outputs","id":"enBv5Pq0knd6M1MQnAQ24","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Setelah Penjumlahan Kelipatan Baris (R3 - R1 -> R3):\n[[ 1.  3.  5.]\n [ 0.  2.  4.]\n [ 0. -1. -1.]]\n"},"children":[],"key":"pODVnS9rDE"}],"key":"JJVEXzlWHW"}],"key":"whj0k6YvfN"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Melanjutkan ke Row Echelon Form (REF)\n# Pada langkah sebelumnya (sebelum sel ini), matriks A adalah:\n# [[ 1.  3.  5.]\n#  [ 0.  2.  4.]\n#  [ 0. -1. -1.]]\n\n# Langkah 4: Hilangkan angka -1 di baris 3 kolom 2 menggunakan baris 2 (R2)\n# Kita bisa menjumlahkan R3 dengan 0.5 * R2 agar elemen di kolom 2 menjadi 0\n# R3 = R3 + 0.5 * R2\nA[2] = A[2] + 0.5 * A[1]\n\nprint(\"Setelah R3 + 0.5 * R2 (Mencapai Bentuk REF):\")\nprint(A)\n\n# Langkah 5 (Opsional): Membuat pivot menjadi 1 (Leading 1)\n# Baris 2 memiliki pivot 2. Kita bagi dengan 2.\n# R2 = 1/2 * R2\nA[1] = 0.5 * A[1]\n\nprint(\"\\nSetelah R2 * 0.5 (Leading 1 pada baris 2):\")\nprint(A)","key":"EEdlEKhbUM"},{"type":"outputs","id":"jZr-KbtkuYOwuKoacGe5v","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Setelah R3 + 0.5 * R2 (Mencapai Bentuk REF):\n[[1. 3. 5.]\n [0. 2. 4.]\n [0. 0. 1.]]\n\nSetelah R2 * 0.5 (Leading 1 pada baris 2):\n[[1. 3. 5.]\n [0. 1. 2.]\n [0. 0. 1.]]\n"},"children":[],"key":"WkLWzGar4q"}],"key":"JIf7sWUnys"}],"key":"z8GxQQGYcX"},{"type":"block","kind":"notebook-content","children":[{"type":"iframe","style":{"border":"0px"},"src":"https://www.geogebra.org/material/iframe/id/qzgpq9gz/width/631/height/400/border/888888/sfsb/true/smb/false/stb/false/stbh/false/ai/false/asb/false/sri/true/rc/false/ld/false/sdz/true/ctl/false","width":"100%","title":"Graph the Line","key":"UTJwas3EVx"}],"key":"ZJ4rBZuWBF"},{"type":"block","kind":"notebook-content","children":[{"type":"iframe","style":{"border":"0px"},"src":"https://www.geogebra.org/material/iframe/id/kpqftj8p/width/631/height/400/border/888888/sfsb/true/smb/false/stb/false/stbh/false/ai/false/asb/false/sri/true/rc/false/ld/false/sdz/true/ctl/false","width":"100%","title":"Graph the Line","key":"hYCoGqs2V7"}],"key":"aNS690JS6j"},{"type":"block","kind":"notebook-content","children":[{"type":"iframe","style":{"border":"0px"},"src":"https://www.geogebra.org/material/iframe/id/mx8ejtvv/width/631/height/400/border/888888/sfsb/true/smb/false/stb/false/stbh/false/ai/false/asb/false/sri/true/rc/false/ld/false/sdz/true/ctl/false","width":"100%","title":"Graph the Line","key":"CrHTaNzeTW"}],"key":"kfMrLh28XN"}],"key":"OPkheG16pl"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Komputasi Aljabar Linear (KAL)","url":"/persamaan-linear","group":"Komputasi Aljabar Linear"},"next":{"title":"Tugas","url":"/tugas-persamaan-gausian","group":"Komputasi Aljabar Linear"}}},"domain":"http://localhost:3000"}